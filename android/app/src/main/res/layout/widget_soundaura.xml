<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="@drawable/widget_background">

        <!-- Título y estado -->
        <LinearLayout
            android:id="@+id/widget_title_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/widget_playlist_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Rolify"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/widget_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Stopped"
                android:textSize="14sp"
                android:textColor="@android:color/white"
                android:alpha="0.8" />
        </LinearLayout>

        <!-- Lista de pistas/playlists -->
        <ListView
            android:id="@+id/widget_soundaura_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:divider="@android:color/transparent"
            android:dividerHeight="4dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp" />

        <!-- Botones de control básicos -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingTop="8dp">

            <ImageButton
                android:id="@+id/widget_play_pause"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/ic_widget_play"
                android:background="@drawable/widget_play_button_bg"
                android:contentDescription="Play/Pause" />

            <ImageButton
                android:id="@+id/widget_stop"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_baseline_stop_24"
                android:background="@android:color/transparent"
                android:contentDescription="Stop"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/widget_master_volume_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="16dp"
                android:gravity="center_vertical"
                android:padding="4dp"
                android:background="@drawable/widget_play_button_bg">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_widget_volume" />
                <TextView
                    android:id="@+id/widget_master_volume_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:text="100%" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
